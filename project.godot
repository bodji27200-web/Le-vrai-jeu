; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="le vrai jeu"
run/main_scene="res://scenes/overworld.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[display]

; Résolution de base fixe + étirement uniforme : le jeu se rend toujours en
; 1152x648 puis est mis à l'échelle pour remplir l'écran (avec bandes noires si
; besoin). Corrige le décalage des persos sur le web (caméra/décor et positions
; fixes enfin alignés) ET allège le GPU (rendu en 1152x648 au lieu du plein
; écran Xbox).
window/size/viewport_width=1152
window/size/viewport_height=648
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[autoload]

Game="*uid://cak4vs1t18duh"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
